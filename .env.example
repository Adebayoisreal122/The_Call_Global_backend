# Server
PORT=5000
NODE_ENV=development

# MongoDB — replace with your Atlas connection string in production
MONGO_URI=mongodb://localhost:27017/thecall-global

# JWT — use a long random string in production (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Admin seed credentials (used only by npm run seed)
ADMIN_EMAIL=admin@thecallglobal.org
ADMIN_PASSWORD=Admin@2024!

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
